# ── DeliverIQ Frontend — Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in the values for your environment.
# ⚠️  NEVER commit .env to version control — it is listed in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # Edit .env, then run: npm run dev

# VITE_API_URL
# Base URL of the DeliverIQ backend API.
#
# Development:
#   Leave EMPTY — Vite's proxy (vite.config.js) forwards /api/* requests to
#   http://localhost:8000 automatically. Setting this in dev would bypass the proxy.
#
# Production (Vercel):
#   Set to your Render backend URL.
#   Example: VITE_API_URL=https://deliveriq-api.onrender.com
#
# Note: All Vite env vars MUST be prefixed with VITE_ to be exposed to the browser.

VITE_API_URL=

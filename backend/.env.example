# ── DeliverIQ Backend — Environment Variables ────────────────────────────────
#
# ⚠️  Copy this file to .env and fill in your values.
# ⚠️  NEVER commit .env to version control — it is listed in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # Edit .env for your environment, then:
#   uvicorn app.main:app --reload

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# Controls logging format and behaviour.
# Values: development | production | test
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────────────────
# CORS_ORIGINS
# Comma-separated list of allowed frontend origins.
#
# Development (Vite default port):
#   CORS_ORIGINS=http://localhost:5173
#
# Production (single origin):
#   CORS_ORIGINS=https://deliver-iq.vercel.app
#
# Production (multiple origins):
#   CORS_ORIGINS=https://deliver-iq.vercel.app,https://www.deliver-iq.com
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FORMAT: text (human-readable, for dev) | json (structured, for prod)
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION EXAMPLE (.env on Render):
#
# ENVIRONMENT=production
# CORS_ORIGINS=https://deliver-iq.vercel.app
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# ─────────────────────────────────────────────────────────────────────────────

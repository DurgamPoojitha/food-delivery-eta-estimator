# ── DeliverIQ — Git Ignore ────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyc

# ── Environment Variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-workspace

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Coverage / Testing ───────────────────────────────────────────────────────
.coverage
htmlcov/
coverage/
.pytest_cache/
